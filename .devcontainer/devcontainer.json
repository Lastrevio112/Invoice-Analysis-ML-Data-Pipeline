{
  "name": "Invoice-Analysis-ML-Data-Pipeline",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbt-labs.dbt-power-user",
        "Fivetran.dbt-language-server",
        "ms-python.python",
        "ms-python.pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "eamodio.gitlens",
        "GitHub.vscode-pull-request-github",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml"
      ],
      "settings": {
        // Python settings — point to the container's Python
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,

        // DBT Power User settings
        "dbt.dbtPythonPathOverride": "/usr/local/bin/python",
        "dbt.projectsDir": "/workspace/dbt",

        // Jupyter settings
        "jupyter.notebookFileRoot": "/workspace",
        "jupyter.kernels.filter": [],

        // Terminal should open at workspace root
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.cwd": "/workspace"
      }
    }
  },

  // Run after the container starts
  "postStartCommand": "echo 'Container ready! Run dbt debug in dbt/ to verify setup.'",

  // Run once after the container is created for the first time
  "postCreateCommand": "cd /workspace/dbt && dbt deps"
}